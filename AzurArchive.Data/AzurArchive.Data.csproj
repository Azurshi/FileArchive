<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
		<TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
		<RootNamespace>AzurArchive.Data</RootNamespace>
		<UseWinUI>true</UseWinUI>
		<WinUISDKReferences>false</WinUISDKReferences>
		<AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
		<Nullable>enable</Nullable>
		<AllowUnsafeBlocks>true</AllowUnsafeBlocks>
		<Optimize Condition="'$(Configuration)' == 'Release'">true</Optimize>

		<Authors>Azurshi</Authors>
		<Version Condition="'$(Configuration)' == 'Debug'">0.1.15-preview</Version>
		<Version Condition="'$(Configuration)' == 'Release'">0.1.16</Version>
		<Description> v0.0: Initial version. v0.1: Refactor and improve data correctness.</Description>
	</PropertyGroup>
	<ItemGroup>
		<PackageReference Include="Blake3" Version="2.2.1" />
		<PackageReference Include="FastCDC" Version="0.1.3" />
		<PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.9" />
		<PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.28000.1839" />
		<PackageReference Include="Microsoft.WindowsAppSDK" Version="2.0.1" />
		<PackageReference Include="SQLiteORM" Version="0.3.19" />
		<PackageReference Include="ZstdNet" Version="1.5.7" />
	</ItemGroup>
	<ItemGroup>
	  <Folder Include="Types\" />
	</ItemGroup>
</Project>