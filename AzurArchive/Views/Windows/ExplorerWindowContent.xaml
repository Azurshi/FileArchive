<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="AzurArchive.Views.Windows.ExplorerWindowContent"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:AzurArchive.Views.Windows"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:control="using:AzurArchive.Views.Controls"
             xmlns:service="using:AzurArchive.Services"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" />
            <RowDefinition Height="*" />
            <RowDefinition Height="32" />
        </Grid.RowDefinitions>
        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />


                <ColumnDefinition Width="*" />
                
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0"
                    Content="&lt;" 
                    Command="{x:Bind ViewModel.BackwardCommand, Mode=OneWay}"/>
            <Button Grid.Column="1"
                    Content=">" 
                    Command="{x:Bind ViewModel.ForwardCommand, Mode=OneWay}"/>
            <Button Grid.Column="2"
                    Content="Refresh" 
                    Command="{x:Bind ViewModel.RefreshCommand, Mode=OneWay}"/>
            <Button Grid.Column="3"
                    Content="Up" 
                    Command="{x:Bind ViewModel.UpCommand, Mode=OneWay}"/>
            <Button Grid.Column="4"
                    Content="Paste"
                    Command="{x:Bind service:Clipboard.PasteCommand}" 
                    CommandParameter="{x:Bind ViewModel.FolderId, Mode=OneWay}"/>
            <Button Grid.Column="5"
                    Content="Import"
                    Command="{x:Bind service:Commands.ImportCommand}"
                    CommandParameter="{x:Bind ViewModel.FolderId, Mode=OneWay}" />
            <Button Grid.Column="6"
                    Content="Info" 
                    Command="{x:Bind ViewModel.InfoCommand, Mode=OneWay}"/>
            <TextBlock Grid.Column="7" 
                       Text="{x:Bind ViewModel.FolderPath, Mode=OneWay}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Stretch"
                       HorizontalTextAlignment="Left"/>
        </Grid>
        <control:FileExplorer Grid.Row="1" 
                              HeaderInfo="{x:Bind ViewModel.HeaderInfo, Mode=OneWay}"
                              ItemsSource="{x:Bind ViewModel.Items, Mode=OneWay}"
                              ItemDoubleClicked="FileExplorer_ItemDoubleClicked"
                              OpenItemCommand="{x:Bind ViewModel.OpenItemCommand, Mode=OneWay}"
                              SelectItemsCommand="{x:Bind ViewModel.SelectItemsCommand, Mode=OneWay}"
                              DeselectItemsCommand="{x:Bind ViewModel.DeselectItemsCommand, Mode=OneWay}" />
        <Grid Grid.Row="2">
            <TextBlock x:Name="LogOutput"
                       VerticalAlignment="Center"
                       Text="Log" />
        </Grid>
    </Grid>

</UserControl>
