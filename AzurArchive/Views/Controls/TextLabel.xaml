<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="AzurArchive.Views.Controls.TextLabel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:AzurArchive.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Margin="4, 0, 0, 0"
             mc:Ignorable="d">
    <RichTextBlock x:Name="InnerTextBlock"
                   TextAlignment="Left"
                   VerticalAlignment="Top"
                   TextTrimming="CharacterEllipsis"
                   TextWrapping="NoWrap"
                   ContextRequested="InnerTextBlock_ContextRequested">
        <Paragraph>
            <Run x:Name="TextContainer"/>
        </Paragraph>
    </RichTextBlock>
</UserControl>
